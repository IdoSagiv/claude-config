    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf *)",
      "Bash(rm -f *)",
      "Bash(sudo rm *)",
      "Bash(shred *)",
      "Bash(truncate *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(git clean *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(git push --force *)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/secrets/**/*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/id_rsa)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/token)",
      "Read(**/credentials)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(sudo *)",
      "Bash(rm *)"
